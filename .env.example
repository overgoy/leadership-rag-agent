# Copy this file to `.env` and fill in your real keys. Never commit `.env`.

# Required: OpenAI key used by litellm for extraction, verification, and the agent.
OPENAI_API_KEY=sk-...

# Required: Tavily key for web search during data collection.
TAVILY_API_KEY=tvly-...

# Optional model overrides (defaults are cost-effective "mini" models, §5 FinOps).
# EXTRACTION_MODEL=gpt-4o-mini   # used by src/scraper.py (extraction + verification)
# AGENT_MODEL=gpt-4o-mini        # used by src/app.py (Text-to-SQL chat agent)